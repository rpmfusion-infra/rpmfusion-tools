#/bin/bash
#
# rpmfusion_sync
#
if [ x${HOSTNAME} != "xbodhi-backend01.online.rpmfusion.net" ] ; then
        echo "Wrong host: run on bodhi-backend01" && exit 1
fi

umask 002

FEDORAS="42 43"
FEDORA_BRANCH="44"
FEDORA_RAWHIDE="45"

for i in nonfree ; do
  for j in ${FEDORAS} ${FEDORA_BRANCH} ${FEDORA_RAWHIDE}; do
    sg sysadmin-build "mkdir -p /pub/${i}/fedora/nvidia-driver/${j}/ "
    sg sysadmin-build "rsync -avHO --no-p /mnt/koji/mash-${USER}/${i}/${j}-nvidia-driver/* /pub/${i}/fedora/nvidia-driver/${j}/ --delete | grep -v -e repodata -e repoview"
  done
done
